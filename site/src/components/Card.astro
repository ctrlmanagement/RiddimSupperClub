---
const { title, subtitle, image, href, class: className = '' } = Astro.props
---

<div class={`card ${className}`}>
  {image && <div class="card__image"><img src={image} alt={title} loading="lazy" /></div>}
  <div class="card__body">
    {title && <h3 class="card__title">{title}</h3>}
    {subtitle && <p class="card__subtitle">{subtitle}</p>}
    <slot />
  </div>
  {href && <a href={href} class="card__link"><span>View more</span></a>}
</div>

<style>
  .card {
    background: var(--color-charcoal);
    border: 1px solid rgba(184, 150, 46, 0.2);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .card:hover {
    border-color: var(--color-gold);
  }
  .card__image img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }
  .card__body {
    padding: var(--space-6);
  }
  .card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-white);
    margin: 0 0 var(--space-2);
    font-weight: normal;
  }
  .card__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-gold);
    margin: 0 0 var(--space-4);
    letter-spacing: 0.05em;
  }
  .card__link {
    display: block;
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid rgba(184, 150, 46, 0.2);
    color: var(--color-gold);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-decoration: none;
    letter-spacing: 0.05em;
  }
  .card__link:hover {
    color: var(--color-gold-light);
  }
</style>
