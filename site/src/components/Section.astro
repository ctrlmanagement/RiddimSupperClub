---
const { id, class: className = '' } = Astro.props
---

<section id={id} class={`section ${className}`}>
  <div class="section__inner">
    <slot />
  </div>
</section>

<style>
  .section {
    padding: var(--space-24) 0;
  }
  .section__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }
</style>
