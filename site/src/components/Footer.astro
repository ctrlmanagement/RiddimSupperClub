---
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">riddim</a>
      <p class="footer__tagline">atlanta's premier supper club</p>
    </div>
    <div class="footer__links">
      <a href="/experience">experience</a>
      <a href="/menu">menu</a>
      <a href="/events">events</a>
      <a href="/gallery">gallery</a>
      <a href="/reserve">reserve</a>
      <a href="/contact">contact</a>
    </div>
    <div class="footer__info">
      <p>atlanta, georgia</p>
      <p>open thursday – sunday</p>
    </div>
  </div>
  <div class="footer__bottom">
    <p>&copy; {new Date().getFullYear()} riddim supper club. all rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-black);
    border-top: 1px solid rgba(184, 150, 46, 0.2);
    padding: var(--space-16) 0 var(--space-8);
  }
  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-8);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-12);
  }
  .footer__logo {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-gold);
    text-decoration: none;
    font-weight: normal;
    display: block;
    margin-bottom: var(--space-2);
  }
  .footer__tagline {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-marble);
    letter-spacing: 0.05em;
    margin: 0;
  }
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer__links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-white);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }
  .footer__links a:hover {
    color: var(--color-gold);
  }
  .footer__info p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-marble);
    margin: 0 0 var(--space-2);
    letter-spacing: 0.05em;
  }
  .footer__bottom {
    max-width: 1200px;
    margin: var(--space-12) auto 0;
    padding: var(--space-6) var(--space-8) 0;
    border-top: 1px solid rgba(184, 150, 46, 0.1);
  }
  .footer__bottom p {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-marble);
    letter-spacing: 0.05em;
    margin: 0;
  }
</style>
