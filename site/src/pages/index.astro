---
import Layout from '../layouts/Layout.astro'
import Section from '../components/Section.astro'
import Button from '../components/Button.astro'
import Card from '../components/Card.astro'
---

<Layout title="Riddim Supper Club — Atlanta">
  <Section>
    <h1>riddim supper club</h1>
    <p>atlanta's premier nightclub, restaurant & hookah lounge</p>
    <Button href="/reserve">book a table</Button>
    <Button variant="secondary" href="/events">view events</Button>
  </Section>
  <Section>
    <Card title="upcoming events" subtitle="this weekend" href="/events" />
    <Card title="vip experience" subtitle="bottle service & private tables" href="/experience" />
    <Card title="the menu" subtitle="cuisine & cocktails" href="/menu" />
  </Section>
</Layout>
